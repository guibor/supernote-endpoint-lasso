SN_ENDPOINT_URL=https://example.com/api/lasso

# Optional request settings
SN_REQUEST_FORMAT=multipart
SN_TIMEOUT_MS=20000
SN_BUTTON_NAME=Send Lasso

# Optional auth
# SN_AUTH_HEADER_NAME=Authorization
# SN_AUTH_HEADER_VALUE=Bearer replace-me

# Optional extra headers as JSON
# SN_EXTRA_HEADERS_JSON={"x-api-key":"replace-me"}

# Optional page PNG behavior
SN_INCLUDE_PAGE_PNG=true
SN_EXPORT_DIR=/storage/emulated/0/Export
SN_PNG_SCALE=1
SN_PNG_BACKGROUND_TYPE=1

# Optional multipart field names
SN_PAYLOAD_FIELD_NAME=payload
SN_IMAGE_FIELD_NAME=page_png
